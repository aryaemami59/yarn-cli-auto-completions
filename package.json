{
  "author": {
    "email": "aryaemami59@yahoo.com",
    "name": "Arya Emami",
    "url": "https://github.com/aryaemami59/yarn-cli-auto-completions.git"
  },
  "bugs": {
    "url": "https://github.com/aryaemami59/yarn-cli-auto-completions/issues"
  },
  "description": "Auto completions for Yarn CLI commands",
  "devDependencies": {
    "@aryaemami59/eslint-config": "^0.0.8",
    "@aryaemami59/prettier-config": "^0.0.8",
    "@aryaemami59/tsconfig": "^0.0.8",
    "@aryaemami59/vitest-config": "^0.0.8",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@yarnpkg/cli": "^4.14.1",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist/",
    "src/"
  ],
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/aryaemami59"
    }
  ],
  "homepage": "https://github.com/aryaemami59/yarn-cli-auto-completions#readme",
  "keywords": [
    "yarn",
    "cli",
    "auto-completions"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "name": "yarn-cli-auto-completions",
  "packageManager": "yarn@4.14.1",
  "publishConfig": {
    "provenance": true
  },
  "repository": {
    "directory": ".",
    "type": "git",
    "url": "https://github.com/aryaemami59/yarn-cli-auto-completions.git"
  },
  "scripts": {
    "build": "node src/index.ts",
    "clean": "rimraf dist/",
    "format": "prettier --ignore-path=$PROJECT_CWD/.gitignore --config=$PROJECT_CWD/prettier.config.mjs --write $INIT_CWD",
    "format-check": "prettier --ignore-path=$PROJECT_CWD/.gitignore --config=$PROJECT_CWD/prettier.config.mjs --check $INIT_CWD",
    "lint": "eslint --config=$PROJECT_CWD/eslint.config.mjs --no-error-on-unmatched-pattern $INIT_CWD",
    "lint-fix": "eslint --config=$PROJECT_CWD/eslint.config.mjs --no-error-on-unmatched-pattern --fix $INIT_CWD",
    "typecheck": "tsc -p $INIT_CWD/tsconfig.json --noEmit"
  },
  "sideEffects": false,
  "source": "./src/index.ts",
  "type": "module",
  "types": "./dist/index.d.ts",
  "version": "1.0.0"
}
